{
  "name": "@metalabel/dfos",
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "clean": "pnpm -r --if-present run clean && pnpm -r exec rm -rf node_modules .turbo tsconfig.tsbuildinfo && rm -rf node_modules .turbo tsconfig.tsbuildinfo",
    "format": "prettier --write .",
    "lint": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^24.10.4",
    "prettier": "^3.8.1",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
