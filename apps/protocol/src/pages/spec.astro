---
import fs from 'node:fs';
import { Marked } from 'marked';
import Base from '../layouts/Base.astro';

// Read PROTOCOL.md at build time from the protocol package
const protocolMd = fs.readFileSync('../../packages/dfos-protocol/PROTOCOL.md', 'utf-8');

function slugify(text: string): string {
  return text
    .replace(/<[^>]*>/g, '')
    .toLowerCase()
    .trim()
    .replace(/[^\w\s-]/g, '')
    .replace(/[\s_]+/g, '-')
    .replace(/^-+|-+$/g, '');
}

const marked = new Marked();
let html = await marked.parse(protocolMd);

// Strip GFM strikethrough — tildes in table cells (e.g. ~3×) get
// misinterpreted as ~~strikethrough~~ across cell boundaries
html = html.replace(/<\/?del>/g, '');

// Add IDs and anchor links to headings for deep linking
html = html.replace(/<h([1-6])>([\s\S]*?)<\/h\1>/g, (_, level, content) => {
  const id = slugify(content);
  return `<h${level} id="${id}"><a href="#${id}" class="anchor" aria-hidden="true">#</a>${content}</h${level}>`;
});
---

<Base
  title="Specification"
  description="Complete DFOS protocol specification — Ed25519 signed chain primitives, identity and content verification, with worked examples and test vectors."
  path="/spec"
>
  <main>
    <nav class="site-nav">
      <a href="/">DFOS Protocol</a>
      <button class="copy-md" id="copy-md" title="Copy as Markdown">copy as md</button>
    </nav>
    <article class="spec" set:html={html} />
  </main>

  <template id="raw-md">{protocolMd}</template>
  <script is:inline>
    document.getElementById('copy-md').addEventListener('click', function () {
      const md = document.getElementById('raw-md').content.textContent;
      navigator.clipboard.writeText(md).then(() => {
        const btn = document.getElementById('copy-md');
        const prev = btn.textContent;
        btn.textContent = 'copied';
        setTimeout(() => (btn.textContent = prev), 1500);
      });
    });
  </script>
</Base>
