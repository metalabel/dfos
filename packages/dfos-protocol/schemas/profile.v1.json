{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.dfos.com/profile/v1",
  "title": "Profile",
  "description": "A profile — the displayable identity for any agent, person, group, or space. Lowest common denominator of a presence in the system.",
  "type": "object",
  "required": ["$schema"],
  "properties": {
    "$schema": {
      "const": "https://schemas.dfos.com/profile/v1"
    },
    "name": {
      "type": "string",
      "description": "Display name."
    },
    "description": {
      "type": "string",
      "description": "Short bio or description."
    },
    "links": {
      "type": "array",
      "maxItems": 20,
      "description": "External links — websites, social profiles, and other URIs.",
      "items": {
        "type": "object",
        "required": ["uri"],
        "properties": {
          "uri": {
            "type": "string",
            "format": "uri",
            "description": "Link target URI."
          },
          "label": {
            "type": "string",
            "description": "Optional short display label for the link."
          },
          "description": {
            "type": "string",
            "description": "Optional longer description of the link."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
