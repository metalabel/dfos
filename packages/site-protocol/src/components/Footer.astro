---
// Shared site footer. One nav for every doc/spec page — rendered from the single
// nav source so it can never drift from the header and landing footers.
import { navLinks } from '../data/nav';
---

<footer class="site-footer">
  <img src="/key-icon-green.svg" alt="" class="footer-key" />
  <nav>
    {navLinks.map(({ href, label }) => <a href={href}>{label}</a>)}
  </nav>
  <p class="credits">
    <a href="https://github.com/metalabel/dfos/blob/main/LICENSE">MIT License</a> &middot; 2026
  </p>
</footer>
