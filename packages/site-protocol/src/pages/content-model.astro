---
import fs from 'node:fs';
import { Marked } from 'marked';
import Base from '../layouts/Base.astro';

// Read CONTENT-MODEL.md at build time from the protocol package
const contentModelMd = fs.readFileSync('../dfos-protocol/CONTENT-MODEL.md', 'utf-8');

function slugify(text: string): string {
  return text
    .replace(/<[^>]*>/g, '')
    .toLowerCase()
    .trim()
    .replace(/[^\w\s-]/g, '')
    .replace(/[\s_]+/g, '-')
    .replace(/^-+|-+$/g, '');
}

const marked = new Marked();
let html = await marked.parse(contentModelMd);

// Fix GFM strikethrough — tildes in table cells (e.g. ~3×) get
// misinterpreted as ~~strikethrough~~. Restore the ~ markers.
html = html.replace(/<del>/g, '~');
html = html.replace(/<\/del>/g, '');

// Wrap tables in scrollable container for mobile
html = html.replace(/<table>/g, '<div class="table-wrap"><table>');
html = html.replace(/<\/table>/g, '</table></div>');

// Wrap code blocks with copy button
html = html.replace(
  /<pre><code(?: class="language-(\w+)")?>/g,
  (_, lang) =>
    `<div class="code-wrap"><button class="code-copy" aria-label="Copy code">copy</button><pre><code${lang ? ` class="language-${lang}"` : ''}>`,
);
html = html.replace(/<\/code><\/pre>/g, '</code></pre></div>');

// Add IDs and anchor links to headings for deep linking
html = html.replace(/<h([1-6])>([\s\S]*?)<\/h\1>/g, (_, level, content) => {
  const id = slugify(content);
  return `<h${level} id="${id}"><a href="#${id}" class="anchor" aria-hidden="true">#</a>${content}</h${level}>`;
});
---

<Base
  title="Content Model"
  description="Standard JSON Schema content types for DFOS — post, profile, and manifest schemas committed via content-addressed CIDs."
  path="/content-model"
>
  <main>
    <nav class="site-nav">
      <a href="/">DFOS Protocol</a>
      <button class="copy-md" id="copy-md" title="Copy as Markdown">copy as md</button>
    </nav>
    <article class="spec" set:html={html} />

    <hr />

    <footer>
      <p class="dim">
        <a href="/">DFOS Protocol</a> · <a href="/spec">Specification</a> ·
        <a href="/did-method">DID Method</a> ·
        <a href="https://github.com/metalabel/dfos">GitHub</a> ·
        <a href="https://dfos.com">dfos.com</a>
      </p>
    </footer>
  </main>

  <template id="raw-md">{contentModelMd}</template>
  <script is:inline>
    document.getElementById('copy-md').addEventListener('click', function () {
      const md = document.getElementById('raw-md').content.textContent;
      navigator.clipboard.writeText(md).then(() => {
        const btn = document.getElementById('copy-md');
        const prev = btn.textContent;
        btn.textContent = 'copied';
        setTimeout(() => (btn.textContent = prev), 1500);
      });
    });
    document.querySelectorAll('.code-copy').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var code = btn.parentElement.querySelector('code').textContent;
        navigator.clipboard.writeText(code).then(function () {
          var prev = btn.textContent;
          btn.textContent = 'copied';
          setTimeout(function () { btn.textContent = prev; }, 1500);
        });
      });
    });
  </script>
</Base>
