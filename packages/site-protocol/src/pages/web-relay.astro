---
import fs from 'node:fs';
import { Marked } from 'marked';
import Base from '../layouts/Base.astro';

// Read WEB-RELAY.md at build time from the specs directory
const relayMd = fs.readFileSync('../../specs/WEB-RELAY.md', 'utf-8');

function slugify(text: string): string {
  return text
    .replace(/<[^>]*>/g, '')
    .toLowerCase()
    .trim()
    .replace(/[^\w\s-]/g, '')
    .replace(/[\s_]+/g, '-')
    .replace(/^-+|-+$/g, '');
}

const marked = new Marked();
let html = await marked.parse(relayMd);

// Fix GFM strikethrough
html = html.replace(/<del>/g, '~');
html = html.replace(/<\/del>/g, '');

// Wrap tables in scrollable container
html = html.replace(/<table>/g, '<div class="table-wrap"><table>');
html = html.replace(/<\/table>/g, '</table></div>');

// Rewrite local markdown links to site URLs
html = html.replace(/href="\.\/PROTOCOL\.md"/g, 'href="/spec"');
html = html.replace(/href="\.\/DID-METHOD\.md"/g, 'href="/did-method"');
html = html.replace(/href="\.\/CONTENT-MODEL\.md"/g, 'href="/content-model"');
html = html.replace(/href="\.\/WEB-RELAY\.md"/g, 'href="/web-relay"');
html = html.replace(/href="\.\/RELAY\.md"/g, 'href="/web-relay"');
html = html.replace(/href="\.\.\/dfos-protocol\/PROTOCOL\.md"/g, 'href="/spec"');
html = html.replace(/href="\.\.\/dfos-protocol\/DID-METHOD\.md"/g, 'href="/did-method"');
html = html.replace(/href="\.\.\/dfos-protocol\/CONTENT-MODEL\.md"/g, 'href="/content-model"');
html = html.replace(/href="\.\/CREDENTIALS\.md"/g, 'href="/credentials"');
html = html.replace(/href="\.\/SIWD\.md"/g, 'href="/siwd"');

// Wrap code blocks with copy button
html = html.replace(
  /<pre><code(?: class="language-(\w+)")?>/g,
  (_, lang) =>
    `<div class="code-wrap"><button class="code-copy" aria-label="Copy code">copy</button><pre><code${lang ? ` class="language-${lang}"` : ''}>`,
);
html = html.replace(/<\/code><\/pre>/g, '</code></pre></div>');

// Add IDs and anchor links to headings
html = html.replace(/<h([1-6])>([\s\S]*?)<\/h\1>/g, (_, level, content) => {
  const id = slugify(content);
  return `<h${level} id="${id}"><a href="#${id}" class="anchor" aria-hidden="true">#</a>${content}</h${level}>`;
});
---

<Base
  title="Web Relay"
  description="DFOS Web Relay — verifying HTTP relay for identity chains, content chains, beacons, countersignatures, and content blobs."
  path="/web-relay"
>
  <div class="page-content spec-width">
    <nav class="site-nav">
      <a href="/">DFOS Protocol</a>
      <button class="copy-md" id="copy-md" title="Copy as Markdown">copy as md</button>
    </nav>
    <article class="spec" set:html={html} />
  </div>

  <footer class="site-footer">
    <img src="/key-icon-green.svg" alt="" class="footer-key" />
    <nav>
      <a href="/">Home</a>
      <a href="/overview">Why</a>
      <a href="/spec">Specification</a>
      <a href="/did-method">DID Method</a>
      <a href="/content-model">Content Model</a>
      <a href="/credentials">Credentials</a>
      <a href="/web-relay">Web Relay</a>
      <a href="/cli">CLI</a>
      <a href="/deploy">Deploy</a>
      <a href="/faq">FAQ</a>
      <a href="https://github.com/metalabel/dfos">GitHub</a>
      <a href="https://dfos.com">dfos.com</a>
    </nav>
    <p class="credits"><a href="https://github.com/metalabel/dfos/blob/main/LICENSE">MIT License</a> &middot; 2026</p>
  </footer>

  <template id="raw-md">{relayMd}</template>
  <script is:inline>
    document.getElementById('copy-md').addEventListener('click', function () {
      const md = document.getElementById('raw-md').content.textContent;
      navigator.clipboard.writeText(md).then(() => {
        const btn = document.getElementById('copy-md');
        const prev = btn.textContent;
        btn.textContent = 'copied';
        setTimeout(() => (btn.textContent = prev), 1500);
      });
    });
    document.querySelectorAll('.code-copy').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var code = btn.parentElement.querySelector('code').textContent;
        navigator.clipboard.writeText(code).then(function () {
          var prev = btn.textContent;
          btn.textContent = 'copied';
          setTimeout(function () { btn.textContent = prev; }, 1500);
        });
      });
    });
  </script>
</Base>
