---
import { Marked } from 'marked';
import Base from '../layouts/Base.astro';
import { overviewMarkdown } from '../content/overview';

const marked = new Marked();
let html = await marked.parse(overviewMarkdown);

// Strip the h1 — we render it explicitly for consistency with other pages
html = html.replace(/^<h1>.*?<\/h1>\n?/, '');
---

<Base
  title="Overview"
  description="Why the DFOS Protocol exists — cryptographic identity without platform trust, offline verification, and verifiable content in private spaces."
  path="/overview"
>
  <div class="page-content">
    <article>
      <h1>Overview</h1>
      <Fragment set:html={html} />
    </article>
  </div>

  <footer class="site-footer">
    <img src="/key-icon-green.svg" alt="" class="footer-key" />
    <nav>
      <a href="/">Home</a>
      <a href="/spec">Specification</a>
      <a href="/did-method">DID Method</a>
      <a href="/content-model">Content Model</a>
      <a href="/web-relay">Web Relay</a>
      <a href="/cli">CLI</a>
      <a href="/deploy">Deploy</a>
      <a href="/skill">Skill</a>
      <a href="/faq">FAQ</a>
      <a href="https://github.com/metalabel/dfos">GitHub</a>
      <a href="https://dfos.com">dfos.com</a>
    </nav>
    <p class="credits"><a href="https://github.com/metalabel/dfos/blob/main/LICENSE">MIT License</a> &middot; 2026</p>
  </footer>
</Base>
