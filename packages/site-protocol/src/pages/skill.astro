---
import fs from 'node:fs';
import SpecPage from '../layouts/SpecPage.astro';

// Full file (with YAML frontmatter) is offered via the copy button; the rendered
// body strips the frontmatter block.
const source = fs.readFileSync('../../specs/CLAUDE-SKILL.md', 'utf-8');
const body = source.replace(/^---\n[\s\S]*?\n---\n/, '');
---

<SpecPage
  title="Claude Code Skill"
  description="DFOS CLI skill for Claude Code — install, configure, and use the protocol CLI with AI-assisted workflows."
  path="/skill"
  source={source}
  body={body}
  copyLabel="copy skill"
  copyTitle="Copy full skill file (with frontmatter) for Claude Code"
>
  <div slot="intro" class="skill-install-note">
    <p>
      This is a <a href="https://docs.anthropic.com/en/docs/claude-code/skills">Claude Code skill</a>
      for the DFOS CLI. To install, copy the skill file and save it to your project:
    </p>
    <div class="code-wrap">
      <button class="code-copy" aria-label="Copy code">copy</button>
      <pre><code>mkdir -p .claude/skills/dfos
# paste into .claude/skills/dfos/SKILL.md</code></pre>
    </div>
  </div>
</SpecPage>
