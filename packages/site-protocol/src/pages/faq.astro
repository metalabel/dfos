---
import Base from '../layouts/Base.astro';
import { faqs } from '../content/faq';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<Base
  title="FAQ"
  description="Frequently asked questions about the DFOS Protocol — cryptographic identity, offline verification, Ed25519 signed chains, and how it compares to alternatives."
  path="/faq"
>
  <main>
    <nav class="site-nav">
      <a href="/">DFOS Protocol</a>
    </nav>

    <article>
      <h1>Frequently Asked Questions</h1>

      {
        faqs.map((faq) => (
          <section class="faq-item">
            <h2>{faq.question}</h2>
            <p set:html={faq.answerHtml ?? faq.answer} />
          </section>
        ))
      }
    </article>

    <hr />

    <footer>
      <nav class="dim" aria-label="Site">
        <a href="/">DFOS Protocol</a> · <a href="/overview">Overview</a> ·
        <a href="/spec">Specification</a> ·
        <a href="/did-method">DID Method</a> ·
        <a href="/content-model">Content Model</a> ·
        <a href="https://github.com/metalabel/dfos">GitHub</a> ·
        <a href="https://dfos.com">dfos.com</a>
      </nav>
    </footer>
  </main>

  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Base>
