---
import Footer from '../components/Footer.astro';
import Base from '../layouts/Base.astro';
import { faqs, faqsToMarkdown } from '../content/faq';

const faqMarkdown = faqsToMarkdown(faqs);

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'DFOS Protocol',
        item: 'https://protocol.dfos.com',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'FAQ',
        item: 'https://protocol.dfos.com/faq',
      },
    ],
  },
];
---

<Base
  title="FAQ"
  description="Frequently asked questions about the DFOS Protocol — cryptographic identity, offline verification, Ed25519 signed chains, and how it compares to alternatives."
  path="/faq"
  schema={schema}
>
  <div class="page-content">
    <nav class="site-nav">
      <a href="/">DFOS Protocol</a>
      <button class="copy-md" id="copy-md" title="Copy as Markdown">copy as md</button>
    </nav>

    <article>
      <h1>Frequently Asked Questions</h1>

      {
        faqs.map((faq) => {
          const id = faq.question.toLowerCase().replace(/[^\w]+/g, '-').replace(/^-|-$/g, '');
          return (
            <section class="faq-item" id={id}>
              <h2><a href={`#${id}`} class="anchor" aria-hidden="true">#</a>{faq.question}</h2>
              <p set:html={faq.answerHtml ?? faq.answer} />
            </section>
          );
        })
      }
    </article>
  </div>

  <Footer />

  <template id="raw-md">{faqMarkdown}</template>
  <script is:inline>
    document.getElementById('copy-md').addEventListener('click', function () {
      const md = document.getElementById('raw-md').content.textContent;
      navigator.clipboard.writeText(md).then(() => {
        const btn = document.getElementById('copy-md');
        const prev = btn.textContent;
        btn.textContent = 'copied';
        setTimeout(() => (btn.textContent = prev), 1500);
      });
    });
  </script>
</Base>
